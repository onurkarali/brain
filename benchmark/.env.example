# Brain Memory Benchmark — API Keys
# Copy to .env and fill in your keys.
# These are passed explicitly to agent subprocesses,
# bypassing keychain issues from HOME isolation.

ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...
# GOOGLE_API_KEY is auto-mapped to GEMINI_API_KEY for Gemini CLI
OPENAI_API_KEY=sk-...
